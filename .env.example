VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
VITE_APP_TYPE=all
VITE_CUSTOMER_APP_URL=http://localhost:5173
VITE_ENABLE_SERVER_RECOMMENDATIONS=true
VITE_ENABLE_KOT_EDGE_PRINT=false
VITE_ENABLE_WHATSAPP_EDGE_NOTIFICATIONS=false
# Emergency-only kill switch. Configured restaurants sync POS orders by default.
VITE_DISABLE_POS_EDGE_SYNC=false
VITE_ENABLE_AR_EDGE_PROCESSING=false
VITE_ENABLE_DELIVERY_QUOTE_EDGE=false
VITE_ENABLE_MENU_CHAT=false
# DANGER: Never set this to true in production. It bypasses session security.
# The build process will throw an error if this is true for any production Vite build.
VITE_ALLOW_CLIENT_ORDER_FALLBACK=false

# Edge Function secrets only. Do not expose through Vite.
APP_ORIGIN=https://menu-verse-admin.vercel.app
ALLOWED_ORIGINS=https://menu-verse-admin.vercel.app,https://menu-verse.vercel.app,https://your-project.supabase.co,http://localhost:5173,http://127.0.0.1:5173
